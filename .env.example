# ===================================================================
# == MirrorMessiah Production Environment Configuration
# ===================================================================
#
# Create a file named '.env' in this directory and copy the contents below.
#
# ===================================================================

# --- Authentication Keys ---
# GATE_KEY: The primary key for family/users to browse and watch movies.
GATE_KEY=your_gate_key_here

# ADMIN_KEY: The key for administrative functions. 
# Restricted to local development for management tools, but serves as master login in production.
ADMIN_KEY=your_admin_key_here

# --- Network & Deployment ---
# The public URL of your application. This should match your Cloudflare Tunnel URL.
# If not set, defaults to http://localhost:3000
NEXTAUTH_URL=https://your-tunnel-subdomain.cloudflareaccess.com

# Your Cloudflare Tunnel Token.
# Get this from the Zero Trust Dashboard -> Access -> Tunnels
# REQUIRED for the 'tunnel' service to start.
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Path to your movie collection on the host machine.
MEDIA_DIR=/path/to/your/movies

# --- OpenSubtitles (Optional: for mm.py fetch-subs) ---
# Register at https://www.opensubtitles.com/en/consumers
OPENSUBS_API_KEY=your_opensubs_api_key
OPENSUBS_USERNAME=your_opensubs_username
OPENSUBS_PASSWORD=your_opensubs_password
